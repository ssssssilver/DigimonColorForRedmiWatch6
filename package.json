{
  "name": "multivpet-dmc-watch",
  "version": "0.3.5",
  "description": "Digital Monster Color style virtual pet game for Xiaomi Vela watches.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "extract:dmc": "node tools/extract-humulos-dmc.mjs",
    "extract:dmc:animations": "node tools/extract-humulos-animation-assets.mjs",
    "debug:vela": "node tools/start-vela-debug.mjs",
    "debug:vela:square": "node tools/start-vela-debug.mjs Vela_Watch_Vpet_Square",
    "debug:vela:round": "node tools/start-vela-debug.mjs Vela_Watch_Vpet",
    "build": "aiot build",
    "release": "aiot release",
    "start": "aiot start --watch",
    "lint:data": "node tools/validate-data.mjs",
    "test:game": "node --no-warnings tools/smoke-test-game.mjs"
  },
  "devDependencies": {
    "@aiot-toolkit/jsc": "^1.0.3",
    "aiot-toolkit": "^2.0.5"
  }
}
