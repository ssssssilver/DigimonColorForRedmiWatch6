<template>
  <div class="vpet-page">
    <div class="{{lcdClass}}">
      <div class="icon-rail top-rail" if="{{!model.showGrave}}">
        <input class="{{statusIconClass}}" type="button" value="口状态" onclick="runAction('status')" />
        <input class="{{foodIconClass}}" type="button" value="●投喂" onclick="runAction('feed')" />
        <input class="{{trainIconClass}}" type="button" value="|训练" onclick="runAction('trainStart')" />
        <input class="{{battleIconClass}}" type="button" value="×战斗" onclick="runAction('battlePreview')" />
      </div>

      <div class="stage-slot">
        <div class="battle-round-scene" if="{{showBattleRound}}">
          <div class="battle-round-row">
            <image class="battle-sprite battle-player" src="{{model.sprite}}"></image>
            <div class="battle-lane">
              <text class="battle-round-title">{{battlePhaseText}}</text>
              <text class="{{battleProjectileClass}}">●</text>
              <text class="{{battleHitClass}}">{{battleHitText}}</text>
            </div>
            <image class="battle-sprite battle-enemy" src="{{model.enemySprite}}"></image>
          </div>
          <text class="battle-round-message">{{battleRoundMessage}}</text>
        </div>

        <div class="battle-scene" if="{{showBattleResult}}">
          <div class="battle-row">
            <image class="battle-sprite" src="{{model.sprite}}"></image>
            <div class="battle-center">
              <text class="battle-vs">战斗</text>
              <text class="battle-result">{{model.battleResultText}}</text>
              <text class="battle-message">{{model.message}}</text>
            </div>
            <image class="battle-sprite" src="{{model.enemySprite}}"></image>
          </div>
          <div class="module-actions battle-actions" if="{{screenMode === 'battleResult'}}">
            <input class="module-action" type="button" value="确认" onclick="runAction('back')" />
          </div>
        </div>

        <div class="battle-preview-scene" if="{{showBattlePreview}}">
          <text class="module-title">战斗</text>
          <image class="battle-sprite enemy-large" src="{{battlePreview.enemySprite}}"></image>
          <text class="enemy-name">{{battlePreview.enemyName}}</text>
          <text class="enemy-meta">{{battlePreview.enemyMeta}}</text>
          <text class="enemy-message">{{battlePreview.message}}</text>
          <div class="module-actions">
            <input class="module-action action-primary" type="button" value="开始" onclick="runAction('battleStart')" />
            <input class="module-action" type="button" value="返回" onclick="runAction('back')" />
          </div>
        </div>

        <div class="train-scene" if="{{showTrain}}">
          <text class="train-title">{{trainTitle}}</text>
          <div class="train-track">
            <div for="{{trainCells}}" class="{{$item.className}}"></div>
          </div>
          <text class="train-readout">{{trainText}}</text>
          <div class="module-actions">
            <input class="module-action action-primary" if="{{screenMode === 'train'}}" type="button" value="停止" onclick="runAction('trainStop')" />
            <input class="module-action action-primary" if="{{screenMode === 'trainResult'}}" type="button" value="确认" onclick="runAction('back')" />
            <input class="module-action" if="{{screenMode === 'train'}}" type="button" value="返回" onclick="runAction('back')" />
          </div>
        </div>

        <div class="recovery-scene" if="{{showRecovery}}">
          <text class="module-icon">!</text>
          <text class="module-title">{{model.recoveryTitle}}</text>
          <text class="module-feedback">{{model.recoveryMessage}}</text>
          <div class="module-actions">
            <input class="module-action action-primary" type="button" value="确认" onclick="runAction('recover')" />
            <input class="module-action" type="button" value="状态" onclick="runAction('status')" />
          </div>
        </div>

        <div class="{{effectClass}}" if="{{showEffect}}">
          <text class="effect-icon">{{effectIcon}}</text>
          <text class="effect-title">{{effectTitle}}</text>
          <text class="effect-message">{{effectMessage}}</text>
        </div>

        <div class="module-scene" if="{{showFeed}}">
          <text class="module-icon">●</text>
          <text class="module-title">投喂</text>
          <text class="module-feedback">{{model.message}}</text>
          <div class="module-actions">
            <input class="module-action action-primary" type="button" value="肉" onclick="runAction('meat')" />
            <input class="module-action action-primary" type="button" value="营养" onclick="runAction('vitamin')" />
            <input class="module-action" type="button" value="返回" onclick="runAction('back')" />
          </div>
        </div>

        <div class="module-scene" if="{{showColdMenu}}">
          <text class="module-icon">*</text>
          <text class="module-title">冷冻</text>
          <text class="module-feedback">{{model.message}}</text>
          <div class="module-actions">
            <input class="module-action action-primary" type="button" value="恢复" onclick="runAction('cold')" />
            <input class="module-action" type="button" value="状态" onclick="runAction('status')" />
            <input class="module-action" type="button" value="返回" onclick="runAction('back')" />
          </div>
        </div>

        <div class="module-scene" if="{{showSleepMenu}}">
          <text class="module-icon">Z</text>
          <text class="module-title">睡觉</text>
          <text class="module-feedback">{{model.message}}</text>
          <div class="module-actions">
            <input class="module-action action-primary" type="button" value="灯光" onclick="runAction('light')" />
            <input class="module-action" type="button" value="冷冻" onclick="runAction('cold')" />
            <input class="module-action" type="button" value="备份" onclick="runAction('backup')" />
            <input class="module-action" type="button" value="返回" onclick="runAction('back')" />
          </div>
        </div>

        <div class="module-scene" if="{{showResetConfirm}}">
          <text class="module-icon">!</text>
          <text class="module-title">新蛋?</text>
          <text class="module-feedback">确认后重新孵化</text>
          <div class="module-actions">
            <input class="module-action action-warn" type="button" value="新蛋" onclick="runAction('reset')" />
            <input class="module-action" type="button" value="返回" onclick="runAction('back')" />
          </div>
        </div>

        <div class="scene" if="{{!showStatus && !showFeed && !showColdMenu && !showSleepMenu && !showResetConfirm && !showRecovery && !showEffect && !showBattleRound && !showBattleResult && !showTrain && !showBattlePreview}}">
          <text class="pet-note">{{petNoteText}}</text>
          <text class="action-feedback" if="{{showActionFeedback}}">{{actionFeedbackText}}</text>
          <text class="grave" if="{{model.showGrave}}">X_X</text>
          <image class="pet-sprite" if="{{model.showSprite && idleFrame === 0}}" src="{{model.idleSprite1}}"></image>
          <image class="pet-sprite" if="{{model.showSprite && idleFrame === 1}}" src="{{model.idleSprite2}}"></image>
          <text class="poop">{{model.poopText}}</text>
        </div>

        <div class="status-scene" if="{{showStatus}}">
          <text for="{{model.statusRows}}" class="status-row">{{$item}}</text>
          <div class="module-actions status-actions">
            <input class="module-action" type="button" value="资料" onclick="runAction('data')" />
            <input class="module-action action-warn" type="button" value="重置" onclick="runAction('resetAsk')" />
            <input class="module-action" type="button" value="返回" onclick="runAction('back')" />
          </div>
        </div>
      </div>

      <div class="bottom-slot">
        <div class="icon-rail bottom-rail" if="{{!model.showGrave && screenMode !== 'resetConfirm'}}">
          <input class="{{wcIconClass}}" type="button" value="o清理" onclick="runAction('toilet')" />
          <input class="{{sleepIconClass}}" type="button" value="Z睡觉" onclick="runAction('sleepMenu')" />
          <input class="{{medIconClass}}" type="button" value="+治疗" onclick="runAction('med')" />
          <input class="{{callIconClass}}" type="button" value="!呼唤" onclick="runAction('call')" />
        </div>

        <div class="icon-rail bottom-rail grave-rail" if="{{model.showGrave && screenMode !== 'resetConfirm'}}">
          <input class="rail-icon sub-icon warn-icon" type="button" value="新蛋" onclick="runAction('resetAsk')" />
        </div>
      </div>
    </div>

    <input class="tap-zone" type="button" value="" onclick="runAction('primaryTap')" />
  </div>
</template>

<script>
import vibrator from '@system.vibrator'
import { applyAction, getBattlePreview, getDisplayModel, getTrainingPreview } from '../../common/utils/gameEngine.js'
import { loadGame, saveGame } from '../../common/utils/gameStore.js'

export default {
  private: {
    state: {},
    model: {
      nameText: '读取中',
      stageText: '-',
      ageText: '0h',
      etaText: '-',
      hungerText: '----',
      strengthText: '----',
      statusText: '启动',
      message: '读取存档...',
      sprite: '',
      idleSprite1: '',
      idleSprite2: '',
      showSprite: false,
      showGrave: false,
      poopText: '',
      callText: '',
      coldText: '',
      sleepText: '',
      questText: 'Q-',
      versionText: 'Ver.5',
      enemySprite: '',
      enemyName: '',
      showBattle: false,
      battleResultText: '',
      showRecovery: false,
      recoveryTitle: '',
      recoveryMessage: ''
    },
    timerId: 0,
    feedbackTimerId: 0,
    effectTimerId: 0,
    battleTimerId: 0,
    battleStepTimerId: 0,
    lastSavedAt: 0,
    lastSavedPet: '',
    screenMode: 'main',
    showStatus: false,
    showFeed: false,
    showTrain: false,
    showBattlePreview: false,
    showBattleRound: false,
    showBattleResult: false,
    showColdMenu: false,
    showSleepMenu: false,
    showResetConfirm: false,
    showRecovery: false,
    showEffect: false,
    showDeadAction: false,
    showCommands: false,
    idleFrame: 0,
    trainValue: 0,
    trainDirection: 1,
    trainTimerId: 0,
    trainMarker: '|---------',
    trainCells: [],
    trainTitle: '蓄力训练',
    trainText: '停止判定',
    lcdClass: 'lcd home-lcd',
    commandMessage: '选择照顾',
    stageAlertText: '',
    petNoteText: '',
    showActionFeedback: false,
    actionFeedbackText: '',
    effectIcon: '',
    effectTitle: '',
    effectMessage: '',
    effectClass: 'effect-scene',
    effectReturnMode: 'main',
    battlePhaseText: '',
    battleHitText: '',
    battleRoundMessage: '',
    battleProjectileClass: 'battle-projectile projectile-hidden',
    battleHitClass: 'battle-hit battle-hit-hidden',
    statusIconClass: 'rail-icon',
    foodIconClass: 'rail-icon',
    trainIconClass: 'rail-icon',
    battleIconClass: 'rail-icon',
    wcIconClass: 'rail-icon',
    medIconClass: 'rail-icon',
    sleepIconClass: 'rail-icon',
    callIconClass: 'rail-icon',
    menuFoodClass: 'action-btn',
    menuWcClass: 'action-btn',
    menuMedClass: 'action-btn',
    menuLightClass: 'action-btn',
    battlePreview: {
      canBattle: false,
      message: '',
      areaText: 'Q-',
      enemyName: '',
      enemySprite: '',
      enemyMeta: ''
    },
    menuOpenedAt: 0,
    modeLabel: '主菜单',
    actions: [
      { id: 'menu', label: '菜单' },
      { id: 'status', label: '状态' },
      { id: 'cold', label: '冷冻' }
    ]
  },
  onInit() {
    loadGame((state) => {
      this.state = state
      this.refresh()
      this.startTicker()
    })
  },
  onShow() {
    this.refresh()
    this.startTicker()
  },
  onHide() {
    this.persistNow()
    this.stopTicker()
  },
  onDestroy() {
    this.persistNow()
    this.stopTicker()
  },
  startTicker() {
    if (this.timerId) return
    this.timerId = setInterval(() => {
      this.idleFrame = this.idleFrame === 0 ? 1 : 0
      this.refresh()
    }, 1000)
  },
  stopTicker() {
    if (!this.timerId) return
    clearInterval(this.timerId)
    this.timerId = 0
    this.stopTrainTicker()
    this.clearFeedbackTimer()
    this.clearEffectTimer()
    this.clearBattleTimers()
  },
  persistNow() {
    if (!this.state.petKey) return
    this.model = getDisplayModel(this.state)
    this.state = this.model.state
    saveGame(this.state)
    this.lastSavedAt = Date.now()
    this.lastSavedPet = this.state.petKey
  },
  refresh() {
    if (!this.state.petKey) return
    this.model = getDisplayModel(this.state)
    this.state = this.model.state
    if (this.screenMode !== 'main' && this.menuOpenedAt && Date.now() - this.menuOpenedAt > 7000) {
      this.screenMode = 'main'
    }
    this.syncMode()
    this.saveIfNeeded()
  },
  runAction(action) {
    if (action === 'primaryTap') {
      if (this.screenMode === 'train') {
        this.runAction('trainStop')
        return
      }
      if (this.screenMode === 'trainResult' || this.screenMode === 'battleResult') {
        this.runAction('back')
        return
      }
      if (this.screenMode === 'battleRound') {
        this.finishBattleSequence()
        return
      }
      if (this.screenMode === 'recovery') {
        this.runAction('recover')
        return
      }
      if (this.screenMode === 'effect') {
        this.closeEffect()
        return
      }
      if (this.screenMode === 'battlePreview') {
        this.runAction('battleStart')
        return
      }
      this.openCommands()
      return
    }
    if (action === 'feed') {
      this.showStageFeedback('投喂', 900)
      this.screenMode = 'feed'
      this.menuOpenedAt = Date.now()
      this.syncMode()
      return
    }
    if (action === 'status') {
      this.showStageFeedback('状态', 900)
      this.screenMode = 'status'
      this.menuOpenedAt = Date.now()
      this.syncMode()
      return
    }
    if (action === 'sleepMenu') {
      this.showStageFeedback('睡觉', 900)
      this.screenMode = 'sleepMenu'
      this.menuOpenedAt = Date.now()
      this.syncMode()
      return
    }
    if (action === 'menu') {
      this.openCommands()
      return
    }
    if (action === 'trainStart') {
      const preview = getTrainingPreview(this.state)
      if (!preview.canTrain) {
        this.state.message = preview.message
        this.showStageFeedback(preview.message)
        this.screenMode = 'main'
        this.syncMode()
        return
      }
      this.showStageFeedback('训练', 900)
      this.screenMode = 'train'
      this.menuOpenedAt = Date.now()
      this.startTrainTicker()
      this.syncMode()
      return
    }
    if (action === 'trainStop') {
      const success = this.trainValue >= 42 && this.trainValue <= 62
      this.stopTrainTicker()
      this.state = applyAction(this.state, success ? 'trainOk' : 'trainMiss')
      this.afterEngineAction(success)
      this.trainTitle = success ? '训练成功' : '训练失败'
      this.trainText = this.state.message
      this.updateTrainCells(success ? 'success' : 'miss')
      this.screenMode = 'trainResult'
      this.menuOpenedAt = Date.now()
      this.syncMode()
      return
    }
    if (action === 'battlePreview') {
      this.showStageFeedback('战斗', 900)
      this.battlePreview = getBattlePreview(this.state)
      this.screenMode = 'battlePreview'
      this.menuOpenedAt = Date.now()
      this.syncMode()
      return
    }
    if (action === 'battleStart') {
      if (!this.battlePreview.canBattle) {
        this.state.message = this.battlePreview.message
        this.showStageFeedback(this.state.message)
        this.screenMode = 'main'
        this.syncMode()
        return
      }
      this.state = applyAction(this.state, 'battle')
      this.afterEngineAction(true)
      this.startBattleSequence()
      return
    }
    if (action === 'recover') {
      this.state = applyAction(this.state, action)
      this.afterEngineAction(false)
      this.showActionEffect(action, 900, 'main')
      return
    }
    if (action === 'resetAsk') {
      this.screenMode = 'resetConfirm'
      this.menuOpenedAt = Date.now()
      this.syncMode()
      return
    }
    if (action === 'back') {
      this.screenMode = 'main'
      this.stopTrainTicker()
      this.clearEffectTimer()
      this.clearBattleTimers()
      this.syncMode()
      return
    }
    this.state = applyAction(this.state, action)
    this.afterEngineAction(action === 'battle' || action === 'cold' || action === 'med')
    if (action === 'meat' || action === 'vitamin') {
      this.showActionEffect(action, 950, 'feed')
      return
    }
    if (action === 'data') {
      this.screenMode = 'status'
      this.menuOpenedAt = Date.now()
      this.syncMode()
      return
    }
    if (action === 'backup') {
      this.showActionEffect(action, 950, 'sleepMenu')
      return
    }
    if (action === 'call') {
      this.showActionEffect(action, 850, 'main')
      return
    }
    if (action === 'cold' && this.state.cold) {
      this.showActionEffect(action, 950, 'coldMenu')
    } else if (action === 'light' && this.state.asleep) {
      this.showActionEffect(action, 950, 'sleepMenu')
    } else if (action === 'toilet' || action === 'med' || action === 'light' || action === 'cold') {
      this.showActionEffect(action, 950, 'main')
    } else {
      this.screenMode = 'main'
      this.showStageFeedback(this.feedbackTextForAction(action))
      this.syncMode()
    }
  },
  afterEngineAction(shouldBuzz) {
    this.model = getDisplayModel(this.state)
    if (shouldBuzz) this.buzz()
    saveGame(this.state)
    this.lastSavedAt = Date.now()
    this.lastSavedPet = this.state.petKey
  },
  feedbackTextForAction(action) {
    if (action === 'meat') return this.state.message === '太饱了' ? '已经吃饱' : '喂肉成功'
    if (action === 'vitamin') return this.state.message.indexOf('过量') >= 0 ? this.state.message : '补剂成功'
    if (action === 'toilet') return this.state.message === '清理完成' ? '清洁' : '已干净'
    if (action === 'med') return this.state.message === '恢复了' ? '恢复' : '无需用药'
    if (action === 'light') return this.state.asleep ? '关灯' : '开灯'
    if (action === 'cold') return this.state.cold ? '冷冻' : '继续'
    if (action === 'backup') return '备份未开放'
    if (action === 'call') return this.state.message
    if (action === 'data') return this.state.message
    if (action === 'reset') return '新蛋'
    return this.state.message || ''
  },
  showStageFeedback(text, duration) {
    if (!text) return
    this.actionFeedbackText = text
    this.showActionFeedback = true
    this.clearFeedbackTimer()
    this.feedbackTimerId = setTimeout(() => {
      this.showActionFeedback = false
      this.actionFeedbackText = ''
      this.feedbackTimerId = 0
    }, duration || 1600)
  },
  clearFeedbackTimer() {
    if (!this.feedbackTimerId) return
    clearTimeout(this.feedbackTimerId)
    this.feedbackTimerId = 0
  },
  showActionEffect(action, duration, returnMode) {
    const effect = this.effectForAction(action)
    this.effectIcon = effect.icon
    this.effectTitle = effect.title
    this.effectMessage = effect.message
    this.effectClass = `effect-scene ${effect.className}`
    this.effectReturnMode = returnMode || 'main'
    this.screenMode = 'effect'
    this.menuOpenedAt = Date.now()
    this.clearEffectTimer()
    this.effectTimerId = setTimeout(() => {
      this.effectTimerId = 0
      this.screenMode = this.effectReturnMode || 'main'
      this.syncMode()
    }, duration || 1000)
    this.syncMode()
  },
  effectForAction(action) {
    if (action === 'meat') return { icon: '●', title: '投喂', message: this.feedbackTextForAction(action), className: 'effect-feed' }
    if (action === 'vitamin') return { icon: '+', title: '营养', message: this.feedbackTextForAction(action), className: 'effect-feed' }
    if (action === 'toilet') {
      const cleaned = this.state.message === '清理完成'
      return { icon: cleaned ? '○' : 'o', title: cleaned ? '清除' : '清理', message: this.feedbackTextForAction(action), className: cleaned ? 'effect-clean effect-clear-done' : 'effect-clean' }
    }
    if (action === 'med') {
      const healed = this.state.message === '恢复了'
      return { icon: '+', title: healed ? '恢复' : '治疗', message: this.feedbackTextForAction(action), className: healed ? 'effect-heal effect-heal-done' : 'effect-heal' }
    }
    if (action === 'light') return { icon: 'Z', title: '灯光', message: this.feedbackTextForAction(action), className: 'effect-sleep' }
    if (action === 'cold') return { icon: '*', title: this.state.cold ? '冷冻' : '恢复', message: this.feedbackTextForAction(action), className: 'effect-cold' }
    if (action === 'backup') return { icon: 'B', title: '备份', message: this.feedbackTextForAction(action), className: 'effect-warn' }
    if (action === 'call') return { icon: '!', title: '呼唤', message: this.feedbackTextForAction(action), className: 'effect-call' }
    if (action === 'recover') return { icon: '!', title: '恢复', message: this.state.message || '已恢复', className: 'effect-heal' }
    return { icon: '!', title: '反馈', message: this.feedbackTextForAction(action), className: '' }
  },
  closeEffect() {
    this.clearEffectTimer()
    this.screenMode = this.effectReturnMode || 'main'
    this.syncMode()
  },
  clearEffectTimer() {
    if (!this.effectTimerId) return
    clearTimeout(this.effectTimerId)
    this.effectTimerId = 0
  },
  startBattleSequence() {
    this.clearBattleTimers()
    this.screenMode = 'battleRound'
    this.menuOpenedAt = Date.now()
    this.battlePhaseText = '战斗'
    this.battleHitText = ''
    this.battleRoundMessage = this.state.lastEnemyName || '战斗开始'
    this.battleProjectileClass = 'battle-projectile projectile-hidden'
    this.battleHitClass = 'battle-hit battle-hit-hidden'
    this.syncMode()
    this.battleStepTimerId = setTimeout(() => {
      this.battlePhaseText = '攻击'
      this.battleRoundMessage = '发射'
      this.battleProjectileClass = 'battle-projectile projectile-fire'
      this.battleHitClass = 'battle-hit battle-hit-hidden'
    }, 450)
    this.battleTimerId = setTimeout(() => {
      const won = this.state.lastBattleWon
      this.battlePhaseText = won ? '命中' : '闪避'
      this.battleHitText = won ? '命中' : '闪避'
      this.battleRoundMessage = won ? '命中目标' : '没有命中'
      this.battleProjectileClass = 'battle-projectile projectile-impact'
      this.battleHitClass = won ? 'battle-hit battle-hit-on' : 'battle-hit battle-miss-on'
      this.battleStepTimerId = setTimeout(() => {
        this.finishBattleSequence()
      }, 700)
    }, 950)
  },
  finishBattleSequence() {
    this.clearBattleTimers()
    this.screenMode = 'battleResult'
    this.menuOpenedAt = Date.now()
    this.syncMode()
  },
  clearBattleTimers() {
    if (this.battleTimerId) {
      clearTimeout(this.battleTimerId)
      this.battleTimerId = 0
    }
    if (this.battleStepTimerId) {
      clearTimeout(this.battleStepTimerId)
      this.battleStepTimerId = 0
    }
  },
  buzz() {
    if (!vibrator || !vibrator.vibrate) return
    vibrator.vibrate({
      mode: 'short',
      success() {},
      fail() {}
    })
  },
  openCommands() {
    if (this.model.showGrave) return
    this.showStageFeedback('选择图标', 900)
  },
  openDefaultMenu() {
    if (this.model.showGrave) return
    if (this.state.cold) {
      this.screenMode = 'coldMenu'
    } else if (this.state.asleep) {
      this.screenMode = 'sleepMenu'
    } else {
      this.screenMode = 'main'
    }
    this.menuOpenedAt = Date.now()
    this.syncMode()
  },
  syncMode() {
    if (this.state.recoveryPending && this.screenMode === 'main') {
      this.screenMode = 'recovery'
    }
    if (!this.state.recoveryPending && this.screenMode === 'recovery') {
      this.screenMode = 'main'
    }
    if (this.state.cold && this.screenMode === 'main') {
      this.screenMode = 'coldMenu'
    }
    if (this.state.asleep && this.screenMode === 'main') {
      this.screenMode = 'sleepMenu'
    }
    this.showStatus = this.screenMode === 'status'
    this.showFeed = this.screenMode === 'feed'
    this.showTrain = this.screenMode === 'train' || this.screenMode === 'trainResult'
    this.showBattlePreview = this.screenMode === 'battlePreview'
    this.showBattleRound = this.screenMode === 'battleRound'
    this.showBattleResult = this.screenMode === 'battleResult' && this.model.showBattle
    this.showColdMenu = this.screenMode === 'coldMenu'
    this.showSleepMenu = this.screenMode === 'sleepMenu'
    this.showResetConfirm = this.screenMode === 'resetConfirm'
    this.showRecovery = this.screenMode === 'recovery'
    this.showEffect = this.screenMode === 'effect'
    this.showDeadAction = this.model.showGrave && this.screenMode !== 'resetConfirm'
    this.showCommands = false
    this.lcdClass = 'lcd home-lcd'
    if (this.state.cold) this.lcdClass = 'lcd home-lcd cold-lcd'
    if (this.state.asleep) this.lcdClass = 'lcd home-lcd sleep-lcd'
    this.stageAlertText = this.model.callText || this.model.coldText || this.model.sleepText || ''
    if (!this.stageAlertText && this.state.sick) this.stageAlertText = '生病'
    if (!this.stageAlertText && this.state.injured) this.stageAlertText = '受伤'
    this.petNoteText = this.model.coldText || this.model.sleepText || ''
    this.syncIconClasses()
    this.commandMessage = this.model.callText ? '呼叫 / 选择照顾' : '选择照顾'
  },
  syncIconClasses() {
    const base = 'rail-icon'
    const active = 'rail-icon icon-active'
    const hot = 'rail-icon icon-hot'
    this.statusIconClass = this.screenMode === 'status' ? active : base
    this.foodIconClass = this.screenMode === 'feed' ? active : (this.state.hunger < 4 || this.state.strength < 4 ? hot : base)
    this.trainIconClass = this.screenMode === 'train' || this.screenMode === 'trainResult' ? active : base
    this.battleIconClass = this.screenMode === 'battlePreview' || this.screenMode === 'battleRound' || this.screenMode === 'battleResult' || this.model.showBattle ? active : base
    this.wcIconClass = this.state.poop > 0 ? hot : base
    this.medIconClass = this.state.sick || this.state.injured ? hot : base
    this.sleepIconClass = this.screenMode === 'sleepMenu' || this.state.asleep || this.state.cold ? active : base
    this.callIconClass = this.state.callActive ? hot : base
  },
  startTrainTicker() {
    this.stopTrainTicker()
    this.trainValue = 0
    this.trainDirection = 1
    this.trainTitle = '蓄力训练'
    this.trainText = '停止判定 0%'
    this.updateTrainMarker()
    this.trainTimerId = setInterval(() => {
      this.trainValue += 10 * this.trainDirection
      if (this.trainValue >= 100) {
        this.trainValue = 100
        this.trainDirection = -1
      }
      if (this.trainValue <= 0) {
        this.trainValue = 0
        this.trainDirection = 1
      }
      this.updateTrainMarker()
    }, 180)
  },
  updateTrainMarker() {
    this.trainMarker = `${Math.round(this.trainValue)}%`
    this.updateTrainCells('')
    this.trainText = `停止判定 ${Math.round(this.trainValue)}%`
  },
  updateTrainCells(result) {
    const index = Math.max(0, Math.min(9, Math.round(this.trainValue / 11)))
    const cells = []
    for (let i = 0; i < 10; i++) {
      let className = i >= 4 && i <= 6 ? 'train-cell train-zone-cell' : 'train-cell'
      if (i === index) className += result === 'success' ? ' train-cell-success' : result === 'miss' ? ' train-cell-miss' : ' train-cell-active'
      cells.push({ className })
    }
    this.trainCells = cells
  },
  stopTrainTicker() {
    if (!this.trainTimerId) return
    clearInterval(this.trainTimerId)
    this.trainTimerId = 0
  },
  saveIfNeeded() {
    const now = Date.now()
    if (this.state.petKey !== this.lastSavedPet || now - this.lastSavedAt > 30000) {
      saveGame(this.state)
      this.lastSavedAt = now
      this.lastSavedPet = this.state.petKey
    }
  }
}
</script>

